# ============================================
# PRODUCTION ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env.production and fill in the values
# DO NOT commit .env.production to version control

# Server Configuration
NODE_ENV=production
PORT=3000

# Session Security (generate a strong random string)
SESSION_SECRET=your-super-secret-session-key-change-this

# MySQL Database Connection
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=demo_kpi
MYSQL_USER=your_db_user
MYSQL_PASSWORD=your_db_password

# CORS (comma-separated list of allowed origins)
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Session Cookie Settings
SESSION_COOKIE_DOMAIN=yourdomain.com
SESSION_COOKIE_SAME_SITE=lax
SESSION_COOKIE_SECURE=true

# Feature Flags (set to 'true' or 'false')
VITE_FEATURE_KPI=true
VITE_FEATURE_PROBATION=true
VITE_FEATURE_PIP=true
VITE_FEATURE_TNA=true
VITE_FEATURE_LMS=true
VITE_FEATURE_CORE=true
VITE_FEATURE_ASSESSMENT=true

# Session Timeout (in minutes)
VITE_SESSION_TIMEOUT_MINUTES=30

# API Base URL (for frontend)
VITE_API_BASE_URL=/api

# Branding (optional)
VITE_APP_NAME=HR Performance Suite
VITE_COMPANY_NAME=Your Company

# Supabase Auth Bridge (migration stage)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Backend read cutover sources (legacy | supabase | auto)
MODULES_READ_SOURCE=auto
LMS_READ_SOURCE=auto
