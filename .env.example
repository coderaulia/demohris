VITE_API_BASE_URL=/api
VITE_API_PROXY_TARGET=http://127.0.0.1:3000
VITE_SESSION_TIMEOUT_MINUTES=30
VITE_MONITOR_WEBHOOK_URL=
VITE_SENTRY_DSN=

PORT=3000
SESSION_SECRET=change-this-in-production
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=demo_kpi
MYSQL_USER=root
MYSQL_PASSWORD=

# Comma-separated frontend origins allowed to call the backend with credentials.
# Example: https://app.example.com,https://demo.example.com
CORS_ALLOWED_ORIGINS=

# Cookie tuning for split frontend/backend deployments.
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_SAME_SITE=none
SESSION_COOKIE_SECURE=true
APP_BASE_URL=http://127.0.0.1:3000
