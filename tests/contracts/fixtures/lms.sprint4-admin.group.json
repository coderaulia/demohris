{
  "id": "lms/sprint4-admin-group",
  "route": "/api",
  "method": "POST",
  "actions": [
    {
      "action": "lms/dashboard/stats",
      "requestPayload": {
        "department": "Human Resources",
        "period": "2026-04"
      },
      "responseRequiredKeys": ["success", "stats"],
      "statsRequiredKeys": ["total_enrollments", "courses_in_progress", "courses_completed", "completion_rate", "avg_score"]
    },
    {
      "action": "lms/dashboard/recommendations",
      "requestPayload": {
        "department": "Human Resources",
        "period": "2026-04"
      },
      "responseRequiredKeys": ["success", "course_performance", "recommendations"]
    },
    {
      "action": "lms/assignments/create",
      "requestPayload": {
        "course_ids": ["course-1", "course-2"],
        "target_type": "department",
        "target_value": "Human Resources",
        "due_date": "2026-05-01"
      },
      "responseRequiredKeys": ["success", "results", "summary", "target"]
    },
    {
      "action": "lms/certificates/list",
      "requestPayload": {
        "employee_id": "employee-1",
        "limit": 20
      },
      "responseRequiredKeys": ["success", "certificates", "meta"]
    },
    {
      "action": "lms/certificates/generate",
      "requestPayload": {
        "enrollment_id": "enrollment-1",
        "reissue": true
      },
      "responseRequiredKeys": ["success", "certificate", "already_issued", "reissued"]
    }
  ]
}
