        "requiredTopLevelKeys": [
          "data"
        ]
      },
      "sideEffects": [
        "update training_need_records.status",
        "set completed_at when status=completed"
      ],
      "followUpReads": [
        "tna/needs",
        "tna/summary"
      ]
    }
  ],
  "firstMutationSliceCandidate": "tna/needs/update-status",
  "firstMutationSliceReason": "Simple status transition with bounded side effects and straightforward follow-up read checks."
